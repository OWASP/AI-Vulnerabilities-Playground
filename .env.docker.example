# Copy to .env in repo root for docker compose:
#   cp .env.docker.example .env
#
# Ollama on the host (default for Docker Desktop / Windows / macOS)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_MODEL_TRAINING_LABS=llama3.1

# Browser origins hitting the nginx entry (http://localhost)
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80,http://127.0.0.1:80

# Redis (compose service name)
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
MEMORY_TTL_SECONDS=3600
SESSION_TTL_SECONDS=3600

# Fingerprinting salt — set a long random string in real deployments
SERVER_SALT=change-me-in-production

AIVP_DEFAULT_MODE=off
ENABLE_TRAINING_LABS=false
AGENT_B_URL=http://agent-b:8001
MM_API_BASE=http://api:8000
API_BASE_URL=http://api:8000
JIRA_URL=https://example.atlassian.net
GITHUB_API_BASE_URL=https://api.github.com
SLACK_API_BASE_URL=https://slack.com/api
VITE_CONTACT_EMAIL=avinash.kumar@owasp.org

# Host port mapped to nginx (default 80)
WEB_PORT=80
